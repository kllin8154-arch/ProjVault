# ProjVault local environment example
#
# Copy values into your shell or deployment secret manager.
# Do not rename this file to .env and commit real values.

# Initial admin account for first boot. Change in shared environments.
PROJVAULT_ADMIN_USERNAME=admin
PROJVAULT_ADMIN_PASSWORD=change-me

# Optional system-level AI provider key.
# Non-admin users can configure their own API key in the UI.
LLM_API_KEY=
ANTHROPIC_API_KEY=

# Production database password.
PROJVAULT_DB_PASSWORD=

# Base64-encoded 32-byte key for production.
# Example generation:
# openssl rand -base64 32
PROJVAULT_SECRETS_MASTER_KEY=

# Optional PDF font path for cross-platform Chinese PDF output.
PROJVAULT_PDF_FONT_PATH=
